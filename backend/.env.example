# ==========================================
# Smart Farming Advisor — Environment Config
# ==========================================

# --- App ---
APP_NAME=Smart Farming Advisor
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://farmer_user:farmer_pass@localhost:5432/farming_db
SYNC_DATABASE_URL=postgresql://farmer_user:farmer_pass@localhost:5432/farming_db

# --- IBM WatsonX (Granite LLM) ---
WATSONX_API_KEY=your-watsonx-api-key-here
WATSONX_PROJECT_ID=your-watsonx-project-id-here
WATSONX_URL=https://eu-gb.dataplatform.cloud.ibm.com
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=farming_knowledge

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu


# --- Market Price API ---
AGMARKNET_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070
AGMARKNET_API_KEY=your-data-gov-api-key

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- Speech ---
SPEECH_LANGUAGE=en-IN
TTS_LANGUAGE=en

# --- RAG Config ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
MIN_RELEVANCE_SCORE=0.3
